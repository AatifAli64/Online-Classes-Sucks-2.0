# Path to your Chrome user data directory
CHROME_PROFILE_PATH="C:\Users\YourUsername\AppData\Local\Google\Chrome\User Data\ respective profile"
PROFILE_DIRECTORY="Default"

# The public ngrok URL of your running Kaggle FastAPI server
KAGGLE_SERVER_URL="https://your-ngrok-url.ngrok-free.app"

# The name to use when joining Microsoft Teams as a guest
GUEST_NAME="Your Full Name"

# ----------------------------
# Google Classroom Links (GCR)
# ----------------------------
# Add the Google Classroom stream URL for each of your subjects.
# These keys must match the "env_link" values in your TIMETABLE below.

GCR_DF="https://classroom.google.com/u/0/c/YOUR_CLASS_ID"
GCR_INFO_SEC="https://classroom.google.com/u/0/c/YOUR_CLASS_ID"
GCR_MA="https://classroom.google.com/u/0/c/YOUR_CLASS_ID"
GCR_AI="https://classroom.google.com/u/0/c/YOUR_CLASS_ID"
GCR_EH_LAB="https://classroom.google.com/u/0/c/YOUR_CLASS_ID"
GCR_DF_LAB="https://classroom.google.com/u/0/c/YOUR_CLASS_ID"
GCR_SEC_SW_D="https://classroom.google.com/u/0/c/YOUR_CLASS_ID"
GCR_SEC_SW_D_LAB="https://classroom.google.com/u/0/c/YOUR_CLASS_ID"
GCR_AI_LAB="https://classroom.google.com/u/0/c/YOUR_CLASS_ID"

# ----------------------------
# Timetable (JSON format)
# ----------------------------
# Define your weekly class schedule.
# Each entry needs: subject name, start time, end time (HH:MM), and env_link key (must match a GCR_ variable above).
#
# Format:
# TIMETABLE='{"DayName": [{"subject": "NAME", "start": "HH:MM", "end": "HH:MM", "env_link": "GCR_KEY"}, ...], ...}'

TIMETABLE='{"Monday": [{"subject": "DF", "start": "08:30", "end": "09:50", "env_link": "GCR_DF"}, {"subject": "Info-Sec", "start": "10:00", "end": "11:20", "env_link": "GCR_INFO_SEC"}], "Tuesday": [{"subject": "DF Lab", "start": "08:30", "end": "11:20", "env_link": "GCR_DF_LAB"}]}'
